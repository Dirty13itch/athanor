{
  "version": "2026-04-11.2",
  "status": "active",
  "source_of_truth": "config/automation-backbone/platform-topology.json",
  "nodes": [
    {
      "id": "dev",
      "label": "DEV",
      "role": "ops_center",
      "default_host": "192.168.1.189",
      "host_envs": ["ATHANOR_DEV_IP", "ATHANOR_DEV_HOST"],
      "description": "Primary operations workstation and support runtime host."
    },
    {
      "id": "foundry",
      "label": "FOUNDRY",
      "role": "heavy_compute",
      "default_host": "192.168.1.244",
      "host_envs": ["ATHANOR_FOUNDRY_IP", "ATHANOR_NODE1_HOST", "ATHANOR_FOUNDRY_HOST"],
      "description": "Heavy inference, multi-GPU, and agent runtime host."
    },
    {
      "id": "workshop",
      "label": "WORKSHOP",
      "role": "creative_compute",
      "default_host": "192.168.1.225",
      "host_envs": ["ATHANOR_WORKSHOP_IP", "ATHANOR_NODE2_HOST", "ATHANOR_WORKSHOP_HOST"],
      "description": "Interactive creative inference and UI-adjacent runtime host."
    },
    {
      "id": "vault",
      "label": "VAULT",
      "role": "storage_observability",
      "default_host": "192.168.1.203",
      "host_envs": ["ATHANOR_VAULT_IP", "ATHANOR_VAULT_HOST"],
      "description": "Primary storage, observability, and shared data host."
    },
    {
      "id": "desk",
