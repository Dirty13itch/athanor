  "protocol_boundary_classes": [
    {
      "id": "internal_control_plane",
      "mutation_authority": "canonical_only",
      "notes": [
        "Never infer internal authority from discovery or edge metadata."
      ]
    },
    {
      "id": "mcp_tool_boundary",
      "mutation_authority": "bounded_by_contract",
      "notes": [
        "Preferred external tool and task boundary."
      ]
    },
    {
      "id": "a2a_edge_boundary",
      "mutation_authority": "none_by_default",
      "notes": [
        "Edge interop only until explicitly promoted."
      ]
    }
  ],
  "server_card_contract": {
    "discovery_surface": "structured metadata over a .well-known URL once standardized",
    "mutation_forbidden": true,
    "scope_rule": "discovery metadata may describe capability but may not outrank canonical registry truth"
  },
  "well_known_metadata_record": {
    "status": "pending_standardization",
    "notes": [
      "Until the Server Card WG output lands, treat well-known metadata as optional discovery only."
    ]
  },
  "session_resumption_policies": [
    {
      "id": "bounded_resume_same_authority",
      "duplicate_execution_forbidden": true,
      "resume_window": "24h",
      "notes": [
        "Session resumption must not create duplicate authority or duplicate execution."
      ]
    },
    {
      "id": "resume_requires_scope_match",
      "duplicate_execution_forbidden": true,
      "resume_window": "12h",
      "notes": [
        "Resumption is denied when scope boundary or authority layer changed materially."
      ]
    }
  ],
  "task_retry_policies": [
    {
      "id": "never_implicit_without_contract",
      "max_attempts": 1,
      "owner": "operator_or_workflow_contract"
    },
    {
      "id": "bounded_transient_retry",
      "max_attempts": 3,
      "owner": "workflow_contract",
      "backoff": "exponential"
    },
    {
      "id": "review_before_replay",
      "max_attempts": 1,
      "owner": "operator_review",
      "backoff": "none"
    }
  ],
