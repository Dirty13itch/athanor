{
  "mcpServers": {
    "grafana": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@leval/mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://192.168.1.203:3000",
        "GRAFANA_USERNAME": "admin",
        "GRAFANA_PASSWORD": "${GRAFANA_PASSWORD}"
      }
    },
    "docker": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-docker.py"],
      "env": {}
    },
    "athanor-agents": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-athanor-agents.py"],
      "env": {
        "ATHANOR_AGENT_URL": "http://192.168.1.244:9000"
      }
    },
    "redis": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-redis.py"],
      "env": {}
    },
    "qdrant": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-qdrant.py"],
      "env": {}
    },
    "smart-reader": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-smart-reader.py"],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {}
    },
    "neo4j": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-neo4j-cypher"],
      "env": {
        "NEO4J_URI": "${NEO4J_URI}",
        "NEO4J_USERNAME": "${NEO4J_USERNAME}",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}"
      }
    },
    "postgres": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "npx -y @zeddotdev/postgres-context-server \"$POSTGRES_URL\""],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "langfuse": {
      "type": "stdio",
      "command": "uvx",
      "args": ["langfuse-mcp"],
      "env": {
        "LANGFUSE_PUBLIC_KEY": "${LANGFUSE_PUBLIC_KEY}",
        "LANGFUSE_SECRET_KEY": "${LANGFUSE_SECRET_KEY}",
        "LANGFUSE_HOST": "${LANGFUSE_HOST}"
      }
    },
    "miniflux": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "miniflux-mcp"],
      "env": {
        "MINIFLUX_URL": "${MINIFLUX_URL}",
        "MINIFLUX_USERNAME": "${MINIFLUX_USERNAME}",
        "MINIFLUX_PASSWORD": "${MINIFLUX_PASSWORD}"
      }
    },
    "n8n": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@illuminaresolutions/n8n-mcp-server"],
      "env": {
        "N8N_BASE_URL": "http://192.168.1.203:5678",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    },
    "gitea": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "$HOME/go/bin/gitea-mcp -t stdio --host http://192.168.1.203:3033 --token $GITEA_TOKEN"],
      "env": {
        "GITEA_TOKEN": "${GITEA_TOKEN}"
      }
    }
  }
}
