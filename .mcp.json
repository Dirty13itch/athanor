{
  "mcpServers": {
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "grafana": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@leval/mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://192.168.1.203:3000",
        "GRAFANA_USERNAME": "${GRAFANA_USERNAME}",
        "GRAFANA_PASSWORD": "${GRAFANA_PASSWORD}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/shaun/repos/Athanor"],
      "env": {}
    },
    "athanor-agents": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-athanor-agents.py"],
      "env": {
        "ATHANOR_AGENT_URL": "http://192.168.1.244:9000"
      }
    }
  }
}
