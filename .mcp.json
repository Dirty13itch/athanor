{
  "mcpServers": {
    "grafana": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec npx -y @leval/mcp-grafana"],
      "env": {}
    },
    "docker": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-docker.py"],
      "env": {}
    },
    "athanor-agents": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-athanor-agents.py"],
      "env": {
        "ATHANOR_AGENT_URL": "http://192.168.1.244:9000"
      }
    },
    "redis": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-redis.py"],
      "env": {}
    },
    "qdrant": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-qdrant.py"],
      "env": {}
    },
    "smart-reader": {
      "type": "stdio",
      "command": "python3",
      "args": ["scripts/mcp-smart-reader.py"],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {}
    },
    "neo4j": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec uvx mcp-neo4j-cypher"],
      "env": {}
    },
    "postgres": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec npx -y @modelcontextprotocol/server-postgres \"$POSTGRES_URL\""],
      "env": {}
    },
    "langfuse": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec uvx langfuse-mcp"],
      "env": {}
    },
    "miniflux": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec npx -y miniflux-mcp"],
      "env": {}
    },
    "n8n": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec node ~/.local/node_modules/@illuminaresolutions/n8n-mcp-server/build/index.js"],
      "env": {}
    },
    "gitea": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "source ~/.claude/mcp-vars.sh && exec $HOME/go/bin/gitea-mcp -t stdio --host http://192.168.1.203:3033 --token \"$GITEA_TOKEN\""],
      "env": {}
    }
  }
}
