{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": {
      "title": "Load Image"
    }
  },
  "2": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    },
    "_meta": {
      "title": "Load Upscale Model (4x-UltraSharp)"
    }
  },
  "3": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["2", 0],
      "image": ["1", 0]
    },
    "_meta": {
      "title": "Upscale Image (4x)"
    }
  },
  "4": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "athanor_upscaled",
      "images": ["3", 0]
    },
    "_meta": {
      "title": "Save Upscaled Image"
    }
  }
}
