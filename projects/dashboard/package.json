{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pretest:e2e:audit": "node scripts/ensure-completion-audit.mjs",
    "test:e2e:audit": "playwright test tests/e2e/api-census.spec.ts tests/e2e/audit-capture.spec.ts tests/e2e/smoke-api.spec.ts tests/e2e/smoke-routes.spec.ts tests/e2e/navigation.spec.ts tests/e2e/operator-controls.spec.ts --project=desktop-chromium --workers=1",
    "test:e2e:terminal": "playwright test tests/e2e/navigation.spec.ts --grep terminal --project=desktop-chromium",
    "smoke:builder-live": "node scripts/smoke-builder-live-route.mjs",
    "typecheck": "node scripts/typecheck.mjs && next typegen && tsc --project tsconfig.typecheck.json --noEmit --incremental false",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lighthouse": "npm run build && lhci autorun"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "axe-core": "^4.11.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
