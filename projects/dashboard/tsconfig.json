{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/routes.d.ts",
    ".next/types/validator.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-playwright-*/types/**/*.ts",
    ".next-playwright-*/dev/types/**/*.ts",
    ".next-playwright-39144/types/**/*.ts",
    ".next-playwright-39144/dev/types/**/*.ts",
    ".next-playwright-39624/types/**/*.ts",
    ".next-playwright-39624/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next-playwright-*",
    "playwright-report",
    "test-results"
  ]
}
