{
  "1": {
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Wan2.2 I2V 14B (GGUF)" },
    "inputs": {
      "model": "Wan2.2-I2V-A14B-HighNoise-Q4_K_S.gguf",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "main_device",
      "attention_mode": "sdpa"
    }
  },
  "8": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": { "title": "UMT5-XXL Text Encoder" },
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "fp8_e4m3fn"
    }
  },
  "2": {
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Text Encoding" },
    "inputs": {
      "positive_prompt": "subtle motion, breathing, blinking, cinematic, photorealistic",
      "negative_prompt": "blurry, low quality, distorted face, ugly, deformed, static image, watermark, text, cartoon, anime, morphing face, identity change",
      "force_offload": true,
      "device": "gpu",
      "t5": ["8", 0],
      "model_to_offload": ["1", 0]
    }
  },
  "15": {
    "class_type": "LoadImage",
    "_meta": { "title": "First Frame (anchor image)" },
    "inputs": {
      "image": "first_frame.jpg",
      "upload": "image"
    }
  },
  "4": {
    "class_type": "WanVideoVAELoader",
    "_meta": { "title": "Video VAE" },
    "inputs": {
      "model_name": "wan_2.1_vae.safetensors",
      "precision": "bf16"
    }
  },
  "3": {
    "class_type": "WanVideoImageToVideoEncode",
    "_meta": { "title": "Encode First Frame for I2V" },
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "noise_aug_strength": 0.025,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "vae": ["4", 0],
      "start_image": ["15", 0]
    }
  },
  "11": {
    "class_type": "WanVideoTeaCache",
    "_meta": { "title": "TeaCache (speed boost)" },
    "inputs": {
      "model": ["1", 0],
      "rel_l1_thresh": 0.15,
      "cache_device": "main_device"
    }
  },
  "5": {
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Sampler" },
    "inputs": {
      "model": ["11", 0],
      "image_embeds": ["3", 0],
      "steps": 25,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "text_embeds": ["2", 0]
    }
  },
  "6": {
    "class_type": "WanVideoDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "vae": ["4", 0],
      "samples": ["5", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "7": {
    "class_type": "RIFE VFI",
    "_meta": { "title": "RIFE Frame Interpolation (2x)" },
    "inputs": {
      "ckpt_name": "rife49.pth",
      "frames": ["6", 0],
      "clear_cache_after_n_frames": 10,
      "multiplier": 2,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float16",
      "torch_compile": false,
      "batch_size": 4
    }
  },
  "9": {
    "class_type": "CreateVideo",
    "_meta": { "title": "Create Video (32fps interpolated)" },
    "inputs": {
      "images": ["7", 0],
      "fps": 32.0
    }
  },
  "10": {
    "class_type": "SaveVideo",
    "_meta": { "title": "Save MP4" },
    "inputs": {
      "video": ["9", 0],
      "filename_prefix": "EoBQ/i2v",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
