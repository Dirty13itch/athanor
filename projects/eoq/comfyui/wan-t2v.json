{
  "1": {
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Wan2.2 T2V 14B Model" },
    "inputs": {
      "model": "wan2.2_t2v_high_noise_14B_fp8_scaled.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "main_device",
      "attention_mode": "sdpa"
    }
  },
  "8": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": { "title": "UMT5-XXL Text Encoder" },
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "fp8_e4m3fn"
    }
  },
  "2": {
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Text Encoding" },
    "inputs": {
      "positive_prompt": "A beautiful woman in a dark fantasy throne room, cinematic, photorealistic",
      "negative_prompt": "blurry, low quality, distorted face, ugly, deformed, static, frozen, watermark, text, cartoon, anime",
      "force_offload": true,
      "device": "gpu",
      "t5": ["8", 0],
      "model_to_offload": ["1", 0]
    }
  },
  "3": {
    "class_type": "WanVideoEmptyEmbeds",
    "_meta": { "title": "Video Dimensions" },
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 81
    }
  },
  "4": {
    "class_type": "WanVideoVAELoader",
    "_meta": { "title": "Video VAE" },
    "inputs": {
      "model_name": "wan_2.1_vae.safetensors",
      "precision": "bf16"
    }
  },
  "5": {
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Sampler" },
    "inputs": {
      "model": ["1", 0],
      "image_embeds": ["3", 0],
      "steps": 25,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "text_embeds": ["2", 0]
    }
  },
  "6": {
    "class_type": "WanVideoDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "vae": ["4", 0],
      "samples": ["5", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "9": {
    "class_type": "CreateVideo",
    "_meta": { "title": "Create Video" },
    "inputs": {
      "images": ["6", 0],
      "fps": 16.0
    }
  },
  "10": {
    "class_type": "SaveVideo",
    "_meta": { "title": "Save MP4" },
    "inputs": {
      "video": ["9", 0],
      "filename_prefix": "EoBQ/video",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
