      "end_at": 1.0
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["16", 0],
      "seed": 42,
      "steps": 25,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "denoise": 1.0
    }
  },
  "20": {
    "class_type": "UltralyticsDetectorProvider",
    "_meta": { "title": "Face Detector (YOLO)" },
    "inputs": {
      "model_name": "bbox/face_yolov8n.pt"
    }
  },
  "21": {
    "class_type": "FaceDetailer",
    "_meta": { "title": "Face Detailer" },
    "inputs": {
