    "inputs": {
      "provider": "CUDA"
    }
  },
  "15": {
    "class_type": "LoadImage",
    "_meta": { "title": "Reference Photo" },
    "inputs": {
      "image": "reference.jpg",
      "upload": "image"
    }
  },
  "16": {
    "class_type": "ApplyPulidFlux",
