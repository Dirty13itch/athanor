      "width": 832,
      "height": 1216,
      "batch_size": 1
    }
  },
  "8": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["8", 0]
    }
  },
  "11": {
    "class_type": "LoraLoaderModelOnly",
