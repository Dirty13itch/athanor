services:
  agents:
    build:
      context: .
      dockerfile: Dockerfile
    image: athanor/agents:latest
    container_name: athanor-agents
    restart: unless-stopped
    network_mode: host
    environment:
      - ATHANOR_VLLM_BASE_URL=http://localhost:{{ vllm_port }}/v1
      - ATHANOR_VLLM_MODEL={{ vllm_model }}
      - ATHANOR_PROMETHEUS_URL={{ prometheus_url }}
      - ATHANOR_PORT={{ agents_port }}
      - ATHANOR_SONARR_API_KEY={{ sonarr_api_key }}
      - ATHANOR_RADARR_API_KEY={{ radarr_api_key }}
      - ATHANOR_TAUTULLI_API_KEY={{ tautulli_api_key }}
