services:
  vllm:
    image: nvcr.io/nvidia/vllm:25.12-py3
    container_name: {{ vllm_container_name | default('vllm') }}
    restart: unless-stopped
    network_mode: host
    ipc: host
    volumes:
      - /mnt/vault/models:/models:ro
    environment:
{% if vllm_gpu_device is defined %}
      - NVIDIA_VISIBLE_DEVICES={{ vllm_gpu_device }}
      - CUDA_VISIBLE_DEVICES={{ vllm_gpu_device }}
{% endif %}
      - VLLM_LOGGING_LEVEL=INFO
    command: >
      python -m vllm.entrypoints.openai.api_server
      --model {{ vllm_model }}
      --quantization {{ vllm_quantization }}
      --dtype float16
      --gpu-memory-utilization {{ vllm_gpu_memory_utilization }}
      --max-model-len {{ vllm_max_model_len }}
      --max-num-seqs {{ vllm_max_num_seqs }}
      --port {{ vllm_port }}
{% if vllm_tensor_parallel is defined %}
      --tensor-parallel-size {{ vllm_tensor_parallel }}
{% endif %}
      {{ vllm_extra_args | default('') }}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
{% if vllm_gpu_device is defined %}
              device_ids: ["{{ vllm_gpu_device }}"]
{% else %}
              count: all
{% endif %}
              capabilities: [gpu]
