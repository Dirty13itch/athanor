groups:
  - name: storage
    rules:
      - alert: VaultDiskCritical
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/mnt/user", instance=~"192.168.1.203.*"} / node_filesystem_size_bytes{mountpoint="/mnt/user", instance=~"192.168.1.203.*"}) > 0.95
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "VAULT data array above 95% ({{ "{{" }} $value | humanizePercentage {{ "}}" }})"
          description: "VAULT /mnt/user is critically full. Immediate cleanup needed."

      - alert: VaultDiskWarning
        expr: (1 - node_filesystem_avail_bytes{mountpoint="/mnt/user", instance=~"192.168.1.203.*"} / node_filesystem_size_bytes{mountpoint="/mnt/user", instance=~"192.168.1.203.*"}) > 0.90
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "VAULT data array above 90% ({{ "{{" }} $value | humanizePercentage {{ "}}" }})"

      - alert: NodeDiskHigh
        expr: (1 - node_filesystem_avail_bytes{fstype=~"ext4|btrfs|xfs", mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) > 0.85
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "{{ "{{" }} $labels.instance {{ "}}" }} root disk above 85%"

  - name: gpu
    rules:
      - alert: GpuTemperatureHigh
        expr: DCGM_FI_DEV_GPU_TEMP > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "GPU {{ "{{" }} $labels.gpu {{ "}}" }} on {{ "{{" }} $labels.instance {{ "}}" }} at {{ "{{" }} $value {{ "}}" }}C"

      - alert: GpuTemperatureCritical
        expr: DCGM_FI_DEV_GPU_TEMP > 95
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "GPU {{ "{{" }} $labels.gpu {{ "}}" }} on {{ "{{" }} $labels.instance {{ "}}" }} CRITICAL {{ "{{" }} $value {{ "}}" }}C"

      - alert: GpuMemoryExhausted
        # vLLM pre-allocates KV cache at startup — normal steady-state is 95-99%.
        # Only alert when VRAM is genuinely exhausted beyond vLLM's allocation.
        expr: (DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE)) > 0.99
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "GPU {{ "{{" }} $labels.gpu {{ "}}" }} VRAM above 99% on {{ "{{" }} $labels.instance {{ "}}" }}"

  - name: backups
    rules:
      - alert: BackupExporterDown
        expr: up{job="backup-exporter"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Backup exporter scrape target is down"
          description: "Prometheus cannot scrape the backup freshness exporter on VAULT :9199."

      - alert: BackupAgeCritical
        expr: athanor_backup_age_seconds > 129600
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "{{ "{{" }} $labels.target {{ "}}" }} backup is older than 36 hours (age: {{ "{{" }} $value | humanizeDuration {{ "}}" }})"
          description: "Check cron jobs and backup scripts. Target: {{ "{{" }} $labels.target {{ "}}" }}"

      - alert: BackupAgeWarning
        expr: athanor_backup_age_seconds > 100800
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "{{ "{{" }} $labels.target {{ "}}" }} backup is older than 28 hours (age: {{ "{{" }} $value | humanizeDuration {{ "}}" }})"

  - name: services
    rules:
      - alert: NodeDown
        expr: up{job=~"node-exporter.*"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Node exporter down on {{ "{{" }} $labels.instance {{ "}}" }}"

      - alert: HighCpuUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 90
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "{{ "{{" }} $labels.instance {{ "}}" }} CPU above 90% for 15m"

      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.90
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "{{ "{{" }} $labels.instance {{ "}}" }} memory above 90%"

  - name: blackbox
    rules:
      - alert: LiteLLMDown
        expr: probe_success{service_id="litellm"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "LiteLLM is down"
          description: "LiteLLM at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: CoordinatorVLLMDown
        expr: probe_success{service_id="foundry-coordinator"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Coordinator vLLM is down"
          description: "Coordinator vLLM at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: CoderVLLMDown
        expr: probe_success{service_id="foundry-coder"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Coder vLLM is down"
          description: "Coder vLLM at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: AgentServerDown
        expr: probe_success{service_id="agent-server"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Agent Server is down"
          description: "Agent Server at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: DashboardDown
        expr: probe_success{service_id="dashboard"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Dashboard is down"
          description: "Dashboard at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: ComfyUIDown
        expr: probe_success{service_id="comfyui"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "ComfyUI is down"
          description: "ComfyUI at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: GiteaDown
        expr: probe_success{service_id="gitea"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Gitea is down"
          description: "Gitea at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: MinifluxDown
        expr: probe_success{service_id="miniflux"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Miniflux is down"
          description: "Miniflux at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."

      - alert: N8nDown
        expr: probe_success{service_id="n8n"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "n8n is down"
          description: "n8n at {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for more than 3 minutes."
