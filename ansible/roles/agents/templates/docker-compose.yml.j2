services:
  agents:
    build:
      context: .
      dockerfile: Dockerfile
    image: athanor/agents:latest
    container_name: athanor-agents
    restart: unless-stopped
    network_mode: host
    volumes:
      # Read-only access to deployed Athanor codebase
      - /opt/athanor:/workspace:ro
      # Writable staging area for task outputs
      - /opt/athanor/agent-output:/output
      # Data curator: personal data synced from DEV (read-only)
      - /opt/athanor/personal-data:/data/personal:ro
      # AUTO-002: Persistent audit log (90-day retention per CONSTITUTION.yaml)
      - /var/log/athanor:/var/log/athanor
    environment:
      - ATHANOR_ENV=dev
      - ATHANOR_NODE1_HOST=${ATHANOR_NODE1_HOST:-{{ agent_node1_host }}}
      - ATHANOR_NODE2_HOST=${ATHANOR_NODE2_HOST:-{{ agent_node2_host }}}
      - ATHANOR_VAULT_HOST=${ATHANOR_VAULT_HOST:-{{ agent_vault_host }}}
      - ATHANOR_DEV_HOST=${ATHANOR_DEV_HOST:-{{ agent_dev_host }}}
      - ATHANOR_LITELLM_URL=${ATHANOR_LITELLM_URL:-{{ agent_litellm_url }}}
      - ATHANOR_LITELLM_API_KEY={{ agent_litellm_api_key }}
      - ATHANOR_LLM_MODEL={{ agent_llm_model }}
      - ATHANOR_LLM_MODEL_FAST={{ agent_llm_model_fast }}
      - ATHANOR_VLLM_COORDINATOR_URL=${ATHANOR_VLLM_COORDINATOR_URL:-{{ agent_vllm_coordinator_url }}}
      - ATHANOR_VLLM_CODER_URL=${ATHANOR_VLLM_CODER_URL:-{{ agent_vllm_coder_url }}}
      - ATHANOR_VLLM_WORKER_URL=${ATHANOR_VLLM_WORKER_URL:-{{ agent_vllm_worker_url }}}
      - ATHANOR_VLLM_EMBEDDING_URL=${ATHANOR_VLLM_EMBEDDING_URL:-{{ agent_vllm_embedding_url }}}
      - ATHANOR_VLLM_RERANKER_URL=${ATHANOR_VLLM_RERANKER_URL:-{{ agent_vllm_reranker_url }}}
      - ATHANOR_AGENT_SERVER_URL=${ATHANOR_AGENT_SERVER_URL:-{{ agent_agent_server_url }}}
      - ATHANOR_DASHBOARD_URL=${ATHANOR_DASHBOARD_URL:-{{ agent_dashboard_url }}}
      - ATHANOR_QDRANT_URL=${ATHANOR_QDRANT_URL:-{{ agent_qdrant_url }}}
      - ATHANOR_REDIS_URL=${ATHANOR_REDIS_URL:-{{ agent_redis_url }}}
      - ATHANOR_REDIS_PASSWORD={{ agent_redis_password }}
      - ATHANOR_POSTGRES_URL=${ATHANOR_POSTGRES_URL:-{{ agent_postgres_url }}}
      - ATHANOR_SUBSCRIPTION_POLICY_PATH=${ATHANOR_SUBSCRIPTION_POLICY_PATH:-{{ agent_subscription_policy_path }}}
      - ATHANOR_TRUTH_INVENTORY_DIR=${ATHANOR_TRUTH_INVENTORY_DIR:-/workspace/reports/truth-inventory}
      - ATHANOR_AGENT_DESCRIPTOR_PATH=${ATHANOR_AGENT_DESCRIPTOR_PATH:-{{ agent_descriptor_path }}}
      - ATHANOR_DOMAIN_PACKET_PATH=${ATHANOR_DOMAIN_PACKET_PATH:-{{ agent_domain_packet_path }}}
      - ATHANOR_NEO4J_URL=${ATHANOR_NEO4J_URL:-{{ agent_neo4j_url }}}
      - ATHANOR_NEO4J_USER=${ATHANOR_NEO4J_USER:-{{ agent_neo4j_user }}}
      - ATHANOR_NEO4J_PASSWORD={{ agent_neo4j_password }}
      - ATHANOR_PROMETHEUS_URL=${ATHANOR_PROMETHEUS_URL:-{{ agent_prometheus_url }}}
      - ATHANOR_GRAFANA_URL=${ATHANOR_GRAFANA_URL:-{{ agent_grafana_url }}}
      - ATHANOR_LANGFUSE_URL=${ATHANOR_LANGFUSE_URL:-{{ agent_langfuse_url }}}
      - ATHANOR_GPU_ORCHESTRATOR_URL=${ATHANOR_GPU_ORCHESTRATOR_URL:-{{ agent_gpu_orchestrator_url }}}
      - ATHANOR_SPEACHES_URL=${ATHANOR_SPEACHES_URL:-{{ agent_speaches_url }}}
      - ATHANOR_HOME_ASSISTANT_URL=${ATHANOR_HOME_ASSISTANT_URL:-{{ agent_home_assistant_url }}}
      - ATHANOR_SONARR_URL=${ATHANOR_SONARR_URL:-{{ agent_sonarr_url }}}
      - ATHANOR_RADARR_URL=${ATHANOR_RADARR_URL:-{{ agent_radarr_url }}}
      - ATHANOR_TAUTULLI_URL=${ATHANOR_TAUTULLI_URL:-{{ agent_tautulli_url }}}
      - ATHANOR_PLEX_URL=${ATHANOR_PLEX_URL:-{{ agent_plex_url }}}
      - ATHANOR_PROWLARR_URL=${ATHANOR_PROWLARR_URL:-{{ agent_prowlarr_url }}}
      - ATHANOR_PROWLARR_API_KEY={{ agent_prowlarr_api_key }}
      - ATHANOR_SABNZBD_URL=${ATHANOR_SABNZBD_URL:-{{ agent_sabnzbd_url }}}
      - ATHANOR_SABNZBD_API_KEY={{ agent_sabnzbd_api_key }}
      - ATHANOR_STASH_URL=${ATHANOR_STASH_URL:-{{ agent_stash_url }}}
      - ATHANOR_COMFYUI_URL=${ATHANOR_COMFYUI_URL:-{{ agent_comfyui_url }}}
      - ATHANOR_OPEN_WEBUI_URL=${ATHANOR_OPEN_WEBUI_URL:-{{ agent_open_webui_url }}}
      - ATHANOR_VAULT_OPEN_WEBUI_URL=${ATHANOR_VAULT_OPEN_WEBUI_URL:-{{ agent_vault_open_webui_url }}}
      - ATHANOR_EOQ_URL=${ATHANOR_EOQ_URL:-{{ agent_eoq_url }}}
      - ATHANOR_PROVIDER_BRIDGE_URL=${ATHANOR_PROVIDER_BRIDGE_URL:-}
      - ATHANOR_PROVIDER_BRIDGE_TOKEN=${ATHANOR_PROVIDER_BRIDGE_TOKEN:-}
      - ATHANOR_PROVIDER_BRIDGE_TIMEOUT_SECONDS=${ATHANOR_PROVIDER_BRIDGE_TIMEOUT_SECONDS:-120}
      - ATHANOR_MINIFLUX_URL=${ATHANOR_MINIFLUX_URL:-{{ agent_miniflux_url }}}
      - ATHANOR_MINIFLUX_USER=${ATHANOR_MINIFLUX_USER:-{{ agent_miniflux_user }}}
      - ATHANOR_MINIFLUX_PASS=${ATHANOR_MINIFLUX_PASS:-{{ agent_miniflux_pass }}}
      - ATHANOR_NTFY_URL=${ATHANOR_NTFY_URL:-{{ agent_ntfy_url }}}
      - ATHANOR_NTFY_TOPIC=${ATHANOR_NTFY_TOPIC:-{{ agent_ntfy_topic }}}
      - ATHANOR_AGENT_API_TOKEN={{ agent_api_token }}
      - ATHANOR_PORT={{ agent_port }}
      - ATHANOR_SONARR_API_KEY={{ agent_sonarr_api_key }}
      - ATHANOR_RADARR_API_KEY={{ agent_radarr_api_key }}
      - ATHANOR_TAUTULLI_API_KEY={{ agent_tautulli_api_key }}
      - ATHANOR_HA_TOKEN={{ agent_ha_token }}
