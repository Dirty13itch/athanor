services:
  vllm:
    image: {{ vllm_image }}
    container_name: {{ vllm_container_name }}
    restart: unless-stopped
{% if vllm_gpu_devices == 'all' %}
    ports:
      - "{{ vllm_port }}:{{ vllm_port }}"
{% else %}
    network_mode: host
{% endif %}
    volumes:
      - /mnt/vault/models:/models:ro
    environment:
      - HF_HUB_OFFLINE=1
      - VLLM_FLASH_ATTN_VERSION=2
      - PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
{% for env in vllm_extra_env %}
      - {{ env }}
{% endfor %}
    ipc: host
    ulimits:
      memlock: -1
      stack: 67108864
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
{% if vllm_gpu_devices == 'all' %}
              count: all
{% else %}
              device_ids: ["{{ vllm_gpu_devices }}"]
{% endif %}
              capabilities: [gpu]
    entrypoint: ["python3", "-m", "vllm.entrypoints.openai.api_server"]
    command:
      - --model
      - {{ vllm_model }}
      - --quantization
      - {{ vllm_quantization }}
      - --tensor-parallel-size
      - "{{ vllm_tensor_parallel }}"
      - --host
      - 0.0.0.0
      - --port
      - "{{ vllm_port }}"
      - --max-model-len
      - "{{ vllm_max_model_len }}"
      - --gpu-memory-utilization
      - "{{ vllm_gpu_memory_util }}"
      - --max-num-seqs
      - "{{ vllm_max_num_seqs }}"
      - --dtype
      - {{ vllm_dtype }}
{% for arg in vllm_extra_args %}
      - {{ arg }}
{% endfor %}
