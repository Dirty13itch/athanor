# Flux LoRA training config — tuned for RTX 5090 32GB
# Generated by Ansible — do not edit directly

[model]
pretrained_model_name_or_path = "{{ flux_model_path }}"
v2 = false
v_parameterization = false

[train]
output_dir = "/output"
output_name = "{{ lora_trigger_word | default('ohwx') }}"
save_model_as = "safetensors"
save_every_n_steps = {{ save_every_n_steps }}
max_train_steps = {{ train_steps }}
train_batch_size = {{ train_batch_size }}
gradient_accumulation_steps = {{ gradient_accumulation_steps }}
mixed_precision = "{{ mixed_precision }}"
seed = 42
clip_skip = 1
max_token_length = 225

[optimizer]
optimizer_type = "prodigy"
learning_rate = {{ learning_rate }}
text_encoder_lr = {{ text_encoder_lr }}
lr_scheduler = "constant"
lr_warmup_steps = 0

[network]
network_module = "networks.lora_flux"
network_dim = {{ lora_rank }}
network_alpha = {{ lora_alpha }}

[dataset]
train_data_dir = "/dataset"
resolution = "{{ resolution }}"
enable_bucket = true
min_bucket_reso = 512
max_bucket_reso = 2048
bucket_reso_steps = 64

[advanced]
cache_latents = true
cache_latents_to_disk = true
cache_text_encoder_outputs = true
cache_text_encoder_outputs_to_disk = true
