services:
  ulrich-energy:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ ulrich_image }}
    container_name: athanor-ulrich-energy
    restart: unless-stopped
    ports:
      - "{{ ulrich_port }}:{{ ulrich_container_port }}"
    environment:
      - ATHANOR_ULRICH_DATABASE_URL={{ ulrich_database_url }}
      - ATHANOR_LITELLM_URL={{ ulrich_litellm_url }}
      - ATHANOR_LITELLM_API_KEY={{ ulrich_litellm_api_key }}
      - DATABASE_URL={{ ulrich_database_url }}
      - LITELLM_BASE_URL={{ ulrich_litellm_base_url }}
      - LITELLM_API_KEY={{ ulrich_litellm_api_key }}
      - TZ=America/Chicago
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
