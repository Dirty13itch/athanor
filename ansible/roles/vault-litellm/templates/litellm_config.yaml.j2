# Athanor LiteLLM Proxy Configuration
# Managed by Ansible - canonical source of truth for model routing
#
# Layout (verified live 2026-04-14):
#   FOUNDRY (.244): dolphin3-r1-24b :8100 primary chat lane, legacy Qwen3.5-27B-FP8 :8000 non-canonical
#   WORKSHOP (.225): Qwen3-VL-8B-Instruct-FP8 :8012
#   DEV (.189): embedding :8001, reranker :8003, CLI proxy :{{ litellm_cliproxy_port }}

model_list:
  # ============================================================
  # LOCAL MODELS (vLLM - always available)
  # ============================================================

  - model_name: "reasoning"
    litellm_params:
      model: "openai/{{ vllm_node1_coder_public_model }}"
      api_base: "http://{{ vllm_node1_host }}:{{ vllm_node1_coder_port }}/v1"
      api_key: "not-needed"
      extra_body:
        chat_template_kwargs:
          enable_thinking: false

