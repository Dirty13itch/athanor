router_settings:
  routing_strategy: simple-shuffle
  num_retries: 2
  timeout: 120
  fallbacks:
    - reasoning: ["fast", "gemini-sub", "deepseek"]
    - coding: ["coder", "reasoning", "gpt-codex-sub", "deepseek"]
    - creative: ["fast", "reasoning", "venice-uncensored"]
    - utility: ["fast", "deepseek"]
    - fast: ["reasoning", "deepseek"]
    - worker: ["reasoning", "deepseek"]
    - coder: ["reasoning", "gpt-codex-sub", "deepseek"]
    - gpt-5.4-sub: ["gemini-sub", "kimi-sub", "deepseek"]
    - gpt-codex-sub: ["gpt-5.4-sub", "gemini-sub"]
    - gemini-sub: ["gpt-5.4-sub", "deepseek"]
    - kimi-sub: ["gemini-sub", "deepseek"]
  context_window_fallbacks:
    - reasoning: ["gemini-sub"]
    - coding: ["gemini-sub"]
    - fast: ["gemini-sub"]
    - coder: ["gemini-sub"]
    - gpt-5.4-sub: ["gemini-sub"]
    - kimi-sub: ["gemini-sub"]
  model_group_alias:
    "gpt-4": { model: "gpt-5.4-sub", hidden: true }
    "gpt-4o": { model: "gpt-5.4-sub", hidden: true }
    "gpt-4o-mini": { model: "fast", hidden: true }
    "gpt-3.5-turbo": { model: "fast", hidden: true }
    "gpt-5.4": { model: "gpt-5.4-sub", hidden: true }
    "claude-sonnet-4": { model: "gpt-5.4-sub", hidden: true }
    "claude-opus-4": { model: "gpt-5.4-sub", hidden: true }
    "claude-sonnet-4-20250514": { model: "gpt-5.4-sub", hidden: true }
    "claude-sonnet-4-6": { model: "gpt-5.4-sub", hidden: true }
    "claude-opus-4-6": { model: "gpt-5.4-sub", hidden: true }
    "claude-haiku-4-5-20251001": { model: "fast", hidden: true }
    "gemini-2.5-pro": { model: "gemini-25-sub", hidden: true }
    "gemini-3.1-pro": { model: "gemini-sub", hidden: true }
    "gemini-pro": { model: "gemini-sub", hidden: true }
    "kimi-k2.5": { model: "kimi-sub", hidden: true }
    "deepseek-coder": { model: "coder", hidden: true }
    "codestral-latest": { model: "coder", hidden: true }
    "text-embedding-ada-002": { model: "embedding", hidden: true }

litellm_settings:
  drop_params: true
  set_verbose: false
  success_callback: ["prometheus", "langfuse"]
  service_callback: ["prometheus_system"]
  failure_callback: ["langfuse"]
  cache: true
  cache_params:
    type: "redis"
    host: "{{ litellm_redis_host }}"
    port: {{ litellm_redis_port }}
    password: "os.environ/REDIS_PASSWORD"
    ttl: 3600

general_settings:
  master_key: "os.environ/LITELLM_MASTER_KEY"
  background_health_checks: true
  health_check_interval: 300
