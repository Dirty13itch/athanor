# Athanor LiteLLM Proxy Configuration
# Managed by Ansible — do not edit manually
#
# Model aliases:
#   "reasoning"  → Qwen3-32B-AWQ on Node 1 (TP=4, 88 GB VRAM)
#   "fast"       → Qwen3-14B on Node 2 (RTX 5090, 32 GB VRAM)
#   "embedding"  → Qwen3-Embedding-0.6B on Node 1 GPU 4

model_list:
  # Primary reasoning model — 32B AWQ, 4-GPU tensor parallel
  - model_name: "reasoning"
    litellm_params:
      model: "hosted_vllm/{{ vllm_node1_model }}"
      api_base: "http://{{ vllm_node1_host }}:{{ vllm_node1_port }}/v1"
      api_key: "not-needed"

  # Fast model — 14B, single GPU, lower latency
  - model_name: "fast"
    litellm_params:
      model: "hosted_vllm/{{ vllm_node2_model }}"
      api_base: "http://{{ vllm_node2_host }}:{{ vllm_node2_port }}/v1"
      api_key: "not-needed"

  # Embedding model — 1024-dim vectors
  - model_name: "embedding"
    litellm_params:
      model: "hosted_vllm/{{ vllm_embedding_model }}"
      api_base: "http://{{ vllm_embedding_host }}:{{ vllm_embedding_port }}/v1"
      api_key: "not-needed"
    model_info:
      mode: embedding

  # Expose the actual model names too (for backwards compat)
  - model_name: "{{ vllm_node1_model }}"
    litellm_params:
      model: "hosted_vllm/{{ vllm_node1_model }}"
      api_base: "http://{{ vllm_node1_host }}:{{ vllm_node1_port }}/v1"
      api_key: "not-needed"

  - model_name: "{{ vllm_node2_model }}"
    litellm_params:
      model: "hosted_vllm/{{ vllm_node2_model }}"
      api_base: "http://{{ vllm_node2_host }}:{{ vllm_node2_port }}/v1"
      api_key: "not-needed"

  - model_name: "{{ vllm_embedding_model }}"
    litellm_params:
      model: "hosted_vllm/{{ vllm_embedding_model }}"
      api_base: "http://{{ vllm_embedding_host }}:{{ vllm_embedding_port }}/v1"
      api_key: "not-needed"
    model_info:
      mode: embedding

  # Cloud fallback (uncomment when ANTHROPIC_API_KEY is set)
  # - model_name: "reasoning"
  #   litellm_params:
  #     model: "anthropic/claude-sonnet-4-20250514"
  #     api_key: "os.environ/ANTHROPIC_API_KEY"

router_settings:
  routing_strategy: simple-shuffle
  num_retries: 2
  timeout: 120
  model_group_alias:
    "gpt-4": { model: "reasoning", hidden: false }
    "gpt-3.5-turbo": { model: "fast", hidden: false }
    "text-embedding-ada-002": { model: "embedding", hidden: false }

litellm_settings:
  drop_params: true
  set_verbose: false

general_settings:
  master_key: "os.environ/LITELLM_MASTER_KEY"
