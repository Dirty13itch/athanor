services:
  eoq:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ eoq_image }}
    container_name: athanor-eoq
    restart: unless-stopped
    ports:
      - "{{ eoq_port }}:{{ eoq_container_port }}"
    volumes:
      - {{ eoq_references_dir }}:/references:rw
    environment:
      - LITELLM_URL={{ eoq_litellm_url }}
      - LITELLM_KEY={{ eoq_litellm_api_key }}
      - COMFYUI_URL={{ eoq_comfyui_url }}
      - QDRANT_URL={{ eoq_qdrant_url }}
      - DIALOGUE_MODEL={{ eoq_dialogue_model }}
      - REFERENCES_DIR=/references
