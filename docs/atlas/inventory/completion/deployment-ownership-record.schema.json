{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment Ownership Record",
  "type": "object",
  "required": [
    "serviceId",
    "title",
    "node",
    "ownerLayer",
    "repoSources",
    "liveEndpoint",
    "liveStatus",
    "driftStatus",
    "completionStatus",
    "notes"
  ],
  "properties": {
    "serviceId": { "type": "string" },
    "title": { "type": "string" },
    "node": { "type": "string" },
    "ownerLayer": {
      "type": "string",
      "enum": ["ansible", "services", "project", "mixed", "live-only"]
    },
    "repoSources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "liveEndpoint": { "type": "string" },
    "liveStatus": {
      "type": "string",
      "enum": ["reachable", "unreachable", "unknown"]
    },
    "driftStatus": {
      "type": "string",
      "enum": ["aligned", "mixed", "diverged", "unknown"]
    },
    "completionStatus": {
      "$ref": "./completion-status.schema.json"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
