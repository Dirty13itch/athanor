{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Release Readiness Report",
  "type": "object",
  "required": [
    "generatedAt",
    "status",
    "summary",
    "blockers",
    "warnings",
    "jobs",
    "inventories"
  ],
  "properties": {
    "generatedAt": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["ready", "blocked"]
    },
    "summary": { "type": "object" },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "jobs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "inventories": { "type": "object" }
  }
}
