{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API Audit Record",
  "type": "object",
  "required": [
    "id",
    "title",
    "apiPath",
    "family",
    "sourceFile",
    "methods",
    "responseMode",
    "consumerStatus",
    "likelyConsumers",
    "coverage",
    "completionStatus",
    "notes"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "apiPath": { "type": "string" },
    "family": { "type": "string" },
    "sourceFile": { "type": "string" },
    "methods": {
      "type": "array",
      "items": { "type": "string" }
    },
    "responseMode": {
      "type": "string",
      "enum": ["json", "sse", "binary", "unknown"]
    },
    "consumerStatus": {
      "type": "string",
      "enum": ["consumed", "support-only", "orphan-candidate"]
    },
    "likelyConsumers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "coverage": {
      "type": "object",
      "required": ["coverageStatus", "localChecks", "liveChecks"],
      "properties": {
        "coverageStatus": { "type": ["string", "null"] },
        "localChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "liveChecks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "completionStatus": {
      "$ref": "./completion-status.schema.json"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
