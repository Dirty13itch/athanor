{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Route Audit Record",
  "type": "object",
  "required": [
    "id",
    "title",
    "kind",
    "routePath",
    "owner",
    "navigation",
    "sourceFiles",
    "coverage",
    "completionStatus",
    "notes"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "kind": { "type": "string", "enum": ["route", "support_surface"] },
    "routePath": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["pageModule", "featureModule"],
      "properties": {
        "pageModule": { "type": ["string", "null"] },
        "featureModule": { "type": ["string", "null"] }
      }
    },
    "navigation": {
      "type": "object",
      "required": ["inPrimaryNavigation", "family", "label", "primary", "mobile"],
      "properties": {
        "inPrimaryNavigation": { "type": "boolean" },
        "family": { "type": ["string", "null"] },
        "label": { "type": ["string", "null"] },
        "primary": { "type": ["boolean", "null"] },
        "mobile": { "type": ["boolean", "null"] }
      }
    },
    "sourceFiles": {
      "type": "object",
      "required": ["primary", "supporting"],
      "properties": {
        "primary": { "type": "string" },
        "supporting": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["coverageStatus", "localChecks", "liveChecks", "primaryControls"],
      "properties": {
        "coverageStatus": { "type": ["string", "null"] },
        "localChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "liveChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primaryControls": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "completionStatus": {
      "$ref": "./completion-status.schema.json"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
